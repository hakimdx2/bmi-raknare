{% extends "base.twig" %}


{% block title %}BMI för Ozempic & Wegovy: Krav & Kriterier (2026){% endblock %}
{% block description %}Vilket BMI krävs för att få Ozempic utskrivet? Läs om de exakta medicinska kriterierna för Ozempic, Wegovy och Mounjaro i Sverige. Testa om du uppfyller kraven.{% endblock %}
{% block canonical %}
	{{ base_url }}/bmi-ozempic-krav/
{% endblock %}

{% block schema %}
	<script type="application/ld+json">
		{
										    "@context": "https://schema.org",
										    "@type": "MedicalWebPage",
										    "name": "Krav för Ozempic och Wegovy i Sverige",
										    "description": "Information om medicinska krav och BMI-gränser för behandling med semaglutid (Ozempic/Wegovy) i Sverige.",
										    "about": {
										        "@type": "MedicalCondition",
										        "name": "Fetma, Övervikt",
										        "alternateName": "Adipositas"
										    },
										    "audience": {
										        "@type": "MedicalAudience",
										        "audienceType": "Patienter"
										    }
										}
	</script>
	<script type="application/ld+json">
		{
										    "@context": "https://schema.org",
										    "@type": "FAQPage",
										    "mainEntity": [
										        {
										            "@type": "Question",
										            "name": "Vilket BMI krävs för Wegovy i Sverige?",
										            "acceptedAnswer": {
										                "@type": "Answer",
										                "text": "För att få Wegovy förskrivet i Sverige krävs oftast ett BMI på minst 30, eller ett BMI på minst 27 om du har viktrelaterade sjukdomar som diabetes typ 2 eller högt blodtryck."
										            }
										        },
										        {
										            "@type": "Question",
										            "name": "Kan man få Ozempic utskrivet för viktminskning?",
										            "acceptedAnswer": {
										                "@type": "Answer",
										                "text": "Ozempic är primärt godkänt för diabetes typ 2. Läkare har dock rätt att skriva ut det 'off-label' för viktminskning om de bedömer att patienten har medicinskt behov av det, men tillgången kan vara begränsad."
										            }
										        },
										        {
										            "@type": "Question",
										            "name": "Vad kostar det?",
										            "acceptedAnswer": {
										                "@type": "Answer",
										                "text": "Kostnaden varierar men ligger ofta mellan 1000 - 3500 SEK per månad om man bekostar det själv utanför högkostnadsskyddet, vilket är fallet för de flesta viktpatienter."
										            }
										        }
										    ]
										}
	</script>
{% endblock %}

{% block content %}
	<div
		class="bg-gray-50 min-h-screen">

		<!-- Hero Header with Medical Trust -->
		<div class="bg-white border-b border-gray-200">
			<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
				<nav class="flex text-sm text-gray-500 mb-4">
					<a href="/" class="hover:text-brand-600 transition-colors">Hem</a>
					<span class="mx-2">/</span>
					<span class="font-medium text-gray-900">Medicinsk Viktminskning</span>
				</nav>
				<div class="flex flex-col md:flex-row md:items-start md:justify-between">
					<div>
						<h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl lg:text-5xl tracking-tight mb-2">
							Vilket BMI krävs för
							<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-teal-500">Ozempic & Wegovy?</span>
						</h1>
						<p class="mt-4 text-xl text-gray-500 max-w-2xl leading-relaxed">
							Guiden till nya tidens viktmediciner i Sverige. Se dina möjligheter, förstå kriterierna och kontrollera ditt BMI direkt.
						</p>
					</div>
					<!-- Trust Badge -->
					<div class="mt-6 md:mt-2 bg-blue-50 border border-blue-100 rounded-2xl p-4 flex items-start max-w-xs shadow-sm">
						<svg class="h-6 w-6 text-blue-600 mr-3 flex-shrink-0 mt-0.5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
						</svg>
						<div>
							<p class="text-sm font-bold text-blue-900">Medicinska Kriterier 2026</p>
							<p class="text-xs text-blue-700 mt-1">Vi baserar våra riktlinjer på Läkemedelsverkets godkännanden och FASS.</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
			<div
				class="grid grid-cols-1 lg:grid-cols-3 gap-12">

				<!-- Main Content -->
				<div
					class="lg:col-span-2">

					<!-- Eligibility Cards -->
					<div
						class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
						<!-- Approved -->
						<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-all">
							<div class="absolute top-0 right-0 w-24 h-24 bg-green-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
							<div class="relative z-10">
								<div class="h-10 w-10 bg-green-100 rounded-full flex items-center justify-center mb-4 text-green-600">
									<svg class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
								</div>
								<h3 class="text-xl font-bold text-gray-900 mb-2">BMI över 30</h3>
								<p class="text-gray-600 text-sm">
									Har du ett BMI på 30 eller högre klassas det som fetma. Du uppfyller grundkravet för medicinsk behandling med Wegovy eller Mounjaro.
								</p>
							</div>
						</div>

						<!-- Conditional -->
						<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-all">
							<div class="absolute top-0 right-0 w-24 h-24 bg-orange-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
							<div class="relative z-10">
								<div class="h-10 w-10 bg-orange-100 rounded-full flex items-center justify-center mb-4 text-orange-600">
									<svg class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
								</div>
								<h3 class="text-xl font-bold text-gray-900 mb-2">BMI 27 - 30</h3>
								<p class="text-gray-600 text-sm">
									Vid övervikt krävs minst en "komorbiditet" (pree-diabetes, högt blodtryck, sömnapné) för att behandling ska vara aktuell.
								</p>
							</div>
						</div>
					</div>

					<!-- Cost Section 2026 -->
					<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 mb-8">
						<h3 class="text-xl font-bold text-gray-900 mb-4">Vad kostar behandlingen 2026?</h3>
						<p class="text-gray-600 text-sm mb-4">Priserna nedan gäller för egenbetalning, då viktminskning normalt inte ingår i högkostnadsskyddet.</p>
						<div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 rounded-lg">
							<table class="min-w-full divide-y divide-gray-300">
								<thead class="bg-gray-50">
									<tr>
										<th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900">Läkemedel</th>
										<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Årskostnad</th>
										<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Månadskostnad</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-gray-200 bg-white">
									<tr>
										<td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">
											<span class="bg-green-100 text-green-600 font-bold px-2 rounded mr-2">Wegovy</span>
										</td>
										<td class="whitespace-nowrap px-3 py-4 text-sm text-gray-700">~37 800 SEK</td>
										<td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">~3 150 SEK</td>
									</tr>
									<tr>
										<td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">
											<span class="bg-blue-100 text-blue-600 font-bold px-2 rounded mr-2">Ozempic</span>
										</td>
										<td class="whitespace-nowrap px-3 py-4 text-sm text-gray-700">~32 400-44 700 SEK</td>
										<td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">~2 700-3 700 SEK</td>
									</tr>
									<tr>
										<td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">
											<span class="bg-purple-100 text-purple-600 font-bold px-2 rounded mr-2">Mounjaro</span>
										</td>
										<td class="whitespace-nowrap px-3 py-4 text-sm text-gray-700">~42 000 SEK</td>
										<td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">~3 500 SEK</td>
									</tr>
								</tbody>
							</table>
						</div>
						<p class="text-xs text-gray-500 mt-3">* Priserna är uppskattningar och kan variera beroende på apotek och dos. Ej subventionerat för viktminskning.</p>
					</div>

					<!-- Mounjaro Card -->
					<div class="bg-gradient-to-r from-purple-50 to-indigo-50 rounded-2xl p-6 shadow-sm border border-purple-100 mb-8">
						<div class="flex items-start">
							<div class="h-10 w-10 bg-purple-100 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
								<svg class="h-6 w-6 text-purple-600" fill="none" viewbox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
								</svg>
							</div>
							<div>
								<h3 class="text-lg font-bold text-purple-900 mb-2">Nytt 2026: Mounjaro (tirzepatid)</h3>
								<p class="text-sm text-purple-800">
									Mounjaro är en ny generation viktmedicin som kombinerar GLP-1 med GIP-hormonet. 
																																													                                Studier visar i genomsnitt
									<strong>22% viktnedgång</strong>
									jämfört med 15% för semaglutid (Wegovy/Ozempic). 
																																													                                Samma BMI-krav gäller: BMI ≥30 eller BMI ≥27 med komorbiditet.
								</p>
							</div>
						</div>
					</div>

					<!-- Calculator Section -->
					<div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-8 sm:p-10 mb-12 ring-4 ring-brand-50" id="kalkylator">
						<div class="text-center mb-8">
							<span class="bg-brand-100 text-brand-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">Steg 1</span>
							<h2 class="text-2xl font-bold text-gray-900 mt-3">Kontrollera ditt BMI nu</h2>
							<p class="text-gray-500">Se om du ligger inom gränsvärdena för behandling.</p>
						</div>
						{% include 'components/calculator.twig' %}
					</div>

					<!-- Article Content -->
					<article class="prose prose-brand prose-lg text-gray-600 bg-white p-8 sm:p-10 rounded-2xl shadow-sm border border-gray-100">
						<h2>Vad är skillnaden på Ozempic och Wegovy?</h2>
						<p>
							Det är en vanlig missuppfattning att det är två olika mediciner. Båda innehåller exakt samma aktiva substans: **semaglutid**.
																																			                        Skillnaden ligger i godkännandet och doseringen:
						</p>
						<ul class="not-prose bg-gray-50 p-6 rounded-xl border border-gray-200 space-y-4 my-6">
							<li class="flex items-start">
								<span class="bg-blue-100 text-blue-600 font-bold px-2 rounded mr-3 mt-1">Ozempic</span>
								<span>Godkänt för
									<strong>Diabetes Typ 2</strong>. Maxdos oftast 1.0 mg.</span>
							</li>
							<li class="flex items-start">
								<span class="bg-green-100 text-green-600 font-bold px-2 rounded mr-3 mt-1">Wegovy</span>
								<span>Godkänt specifikt för
									<strong>Viktminskning</strong>. Kan titreras upp till 2.4 mg.</span>
							</li>
						</ul>

						<h3>Hur fungerar det?</h3>
						<p>
							Semaglutid efterliknar ett kroppseget hormon (GLP-1) som frisätts i tarmen när vi äter. Det skickar signaler till hjärnan om att
																																			                        du är mätt, vilket gör att du äter mindre portioner och tänker mindre på mat (minskat "matbrus"). Det saktar också ner tömningen av magsäcken.
						</p>

						<h2>Vanliga biverkningar</h2>
						<p>
							Majoriteten av biverkningarna är kopplade till mage och tarm och går ofta över efter några veckor när kroppen vant sig.
						</p>
						<ul>
							<li>Illamående (mycket vanligt)</li>
							<li>Diarré eller förstoppning</li>
							<li>Trötthet och huvudvärk</li>
						</ul>
						<p>
							För att minska risken för biverkningar börjar man alltid på en mycket låg dos och trappar upp långsamt över flera månader.
						</p>

						<h3>Vem ska INTE ta det?</h3>
						<p>
							Medicinen rekommenderas inte om du är gravid, planerar att bli gravid, eller har historik av vissa sköldkörtelsjukdomar (MTC).
						</p>

						<div class="mt-8 p-6 bg-red-50 rounded-xl border border-red-100 flex flex-col sm:flex-row items-center justify-between gap-6">
							<div>
								<h4 class="text-red-900 font-bold text-lg m-0 mb-1">Varning</h4>
								<p class="text-red-800 text-sm m-0">Köp aldrig receptbelagda mediciner på svarta marknaden eller oseriösa sajter. Det kan vara livsfarligt.</p>
							</div>
						</div>

						{# Premium SEO Content Component #}
						{% include 'components/content-ozempic.twig' %}

					</article>
				</div>

				<!-- Sidebar -->
				{% include 'components/sidebar.twig' %}

			</div>
		</div>
	</div>
{% endblock %}
