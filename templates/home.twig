{% extends "base.twig" %}

{% set current_month = "now"|date("F") %}
{% set current_year = "now"|date("Y") %}
{% set swedish_months = {
    'January': 'Januari', 'February': 'Februari', 'March': 'Mars', 'April': 'April',
    'May': 'Maj', 'June': 'Juni', 'July': 'Juli', 'August': 'Augusti',
    'September': 'September', 'October': 'Oktober', 'November': 'November', 'December': 'December'
} %}
{% set month_sv = swedish_months[current_month] %}

{% block title %}BMI Räknare — Räkna ut ditt BMI Direkt | Gratis för Kvinnor, Män & Barn{% endblock %}
{% block description %}Räkna ut ditt BMI direkt på sidan. Gratis BMI-kalkylator för kvinnor, män och barn — anpassad efter ålder och kön. Baserat på WHO:s riktlinjer.{% endblock %}
{% block canonical %}
	{{ base_url }}/
{% endblock %}

{% block content %}
	<div class="bg-gradient-to-b from-white to-gray-50">
		<div
			class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">

			<!-- Hero Section -->
			<div class="text-center mb-12">
				<h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl tracking-tight">
					<span class="block text-brand-600">BMI Räknare</span>
					<span class="block text-2xl sm:text-3xl font-medium text-gray-500 mt-2">Räkna ut ditt BMI gratis & direkt</span>
				</h1>
				<p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
					Använd vår avancerade kalkylator för kvinnor, män och barn. Vi tar hänsyn till ålder och kön för att ge dig ett exakt resultat.
				</p>
			</div>

			<!-- Calculator Card -->
			<div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
				<div class="p-6 sm:p-10">
					{% include 'components/calculator.twig' %}
				</div>
				<div class="bg-gray-50 px-6 py-4 border-t border-gray-100 flex items-center justify-between">
					<div class="flex items-center space-x-2 text-sm text-gray-500">
						<svg class="h-5 w-5 text-green-500" fill="none" viewbox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
						<span>Baserat på WHO:s riktlinjer</span>
					</div>
					<div class="text-sm text-gray-400">
						Uppdaterad:
						{{ "now"|date("Y-m-d") }}
					</div>
				</div>
			</div>

			<!-- Trust / Content Section -->
			<!-- Content & FAQ Section -->
			<div
				class="max-w-3xl mx-auto mt-16">

				<!-- Medical Trust Signals -->
				<div class="mb-12">
					{% include 'components/medical-review.twig' %}
				</div>

				<div class="prose prose-brand prose-lg text-gray-600 mb-10">
					<h2 class="text-3xl font-bold text-center mb-8">Vanliga frågor om BMI</h2>
				</div>

				<!-- FAQ Accordion -->
				<div
					class="space-y-4" x-data="{ active: null }">

					<!-- Q1 -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 1 ? null : 1)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Vad är BMI?</h3>
							<span x-show="active !== 1" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 1" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 1" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>BMI (Body Mass Index) är ett grovt mått som används av WHO och vården för att klassificera vikt i relation till längd. Det ger en snabb indikation på om du ligger i riskzonen för undervikt, övervikt eller fetma.</p>
							</div>
						</div>
					</div>

					<!-- Q2 -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 2 ? null : 2)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Vilket BMI ska man ha?</h3>
							<span x-show="active !== 2" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 2" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 2" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>Enligt standarden anses ett BMI mellan
									<strong>18.5 och 25</strong>
									vara normalvikt för vuxna. För personer över 65 år är idealet högre, mellan
									<strong>22 och 29</strong>.</p>
							</div>
						</div>
					</div>

					<!-- Q3 -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 3 ? null : 3)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Hur räknas BMI ut?</h3>
							<span x-show="active !== 3" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 3" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 3" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>Formeln är enkel:
									<code>Vikt (kg) / (Längd (m) * Längd (m))</code>. Vår kalkylator gör detta automatiskt, och du behöver inte konvertera din längd till meter själv.</p>
							</div>
						</div>
					</div>

					<!-- Q4 -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 4 ? null : 4)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Är BMI ett bra mått?</h3>
							<span x-show="active !== 4" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 4" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 4" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>BMI är ett bra generellt verktyg men det skiljer inte på fett och muskler. Därför har vi lagt till funktionen
									<strong>Midjemått</strong>
									i vår räknare för att ge en mer rättvisande bild av din hälsa.</p>
							</div>
						</div>
					</div>

					<!-- Q5 - NEW -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 5 ? null : 5)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Hur påverkas BMI av ålder?</h3>
							<span x-show="active !== 5" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 5" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 5" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>Med stigande ålder förändras kroppens sammansättning. Muskelmassa minskar naturligt medan fettandelen ökar. Därför rekommenderas ett något högre BMI för
									<a href="/bmi-aldre/">personer över 65 år</a>
									(22-29 istället för 18.5-25) för att säkerställa tillräckliga energireserver vid sjukdom.</p>
							</div>
						</div>
					</div>

					<!-- Q6 - NEW -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 6 ? null : 6)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Vad är farligast – undervikt eller övervikt?</h3>
							<span x-show="active !== 6" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 6" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 6" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>Både undervikt och övervikt medför hälsorisker. Undervikt (BMI under 18.5) kan leda till näringsbrist, försämrat immunförsvar och benskörhet. Övervikt (BMI över 25) ökar risken för hjärt-kärlsjukdomar, typ 2-diabetes och vissa cancerformer. Enligt studier är måttlig övervikt generellt mindre riskfyllt än kraftig undervikt.</p>
							</div>
						</div>
					</div>

					<!-- Q7 - NEW -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 7 ? null : 7)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Fungerar BMI för barn?</h3>
							<span x-show="active !== 7" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 7" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 7" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>Nej, för barn används
									<strong>ISO-BMI</strong>
									som tar hänsyn till att barn växer olika beroende på ålder och kön. Standardgränsvärdena för vuxna gäller inte barn. Vår
									<a href="/bmi-barn/">BMI-räknare för barn</a>
									använder tillväxtkurvor och percentiler enligt svenska barnhälsovårdens rekommendationer.</p>
							</div>
						</div>
					</div>

					<!-- Q8 - NEW -->
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<button @click="active = (active === 8 ? null : 8)" class="w-full px-6 py-4 text-left flex justify-between items-center focus:outline-none bg-gray-50 hover:bg-gray-100 transition-colors">
							<h3 class="text-lg font-medium text-gray-900">Vad är midjemått och varför är det viktigt?</h3>
							<span x-show="active !== 8" class="text-gray-500 text-2xl font-light">+</span>
							<span x-show="active === 8" class="text-brand-600 text-2xl font-light" style="display: none;">−</span>
						</button>
						<div x-show="active === 8" x-collapse style="display: none;">
							<div class="px-6 py-4 text-gray-600 border-t border-gray-100">
								<p>Midjemått mäter bukfetma, som är en starkare riskfaktor för hjärt-kärlsjukdomar än BMI ensamt. Enligt 1177 Vårdguiden bör midjemåttet vara under
									<strong>80 cm för kvinnor</strong>
									och
									<strong>94 cm för män</strong>. Över dessa värden ökar hälsoriskerna markant. Vår kalkylator låter dig ange midjemått för en mer komplett riskbedömning.</p>
							</div>
						</div>
					</div>

				</div>

				<!-- BMI Table Summary -->
				<div class="mt-12 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">BMI-tabell: Gränsvärden enligt WHO</h2>
					<div class="overflow-x-auto">
						<table class="min-w-full divide-y divide-gray-200">
							<thead class="bg-gray-50">
								<tr>
									<th class="px-4 py-3 text-left text-sm font-semibold text-gray-900">Klassificering</th>
									<th class="px-4 py-3 text-left text-sm font-semibold text-gray-900">BMI-intervall</th>
									<th class="px-4 py-3 text-left text-sm font-semibold text-gray-900">Hälsorisk</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-gray-200">
								<tr>
									<td class="px-4 py-3 text-sm text-gray-900">Undervikt</td>
									<td class="px-4 py-3 text-sm text-blue-600 font-medium">&lt; 18.5</td>
									<td class="px-4 py-3 text-sm text-gray-600">Ökad risk för näringsbrist</td>
								</tr>
								<tr class="bg-green-50">
									<td class="px-4 py-3 text-sm text-green-800 font-medium">Normalvikt</td>
									<td class="px-4 py-3 text-sm text-green-700 font-bold">18.5 – 24.9</td>
									<td class="px-4 py-3 text-sm text-green-700">Lägst hälsorisk</td>
								</tr>
								<tr>
									<td class="px-4 py-3 text-sm text-gray-900">Övervikt</td>
									<td class="px-4 py-3 text-sm text-yellow-600 font-medium">25.0 – 29.9</td>
									<td class="px-4 py-3 text-sm text-gray-600">Måttligt ökad risk</td>
								</tr>
								<tr>
									<td class="px-4 py-3 text-sm text-gray-900">Fetma klass I</td>
									<td class="px-4 py-3 text-sm text-orange-600 font-medium">30.0 – 34.9</td>
									<td class="px-4 py-3 text-sm text-gray-600">Hög risk</td>
								</tr>
								<tr>
									<td class="px-4 py-3 text-sm text-gray-900">Fetma klass II-III</td>
									<td class="px-4 py-3 text-sm text-red-600 font-medium">&gt; 35</td>
									<td class="px-4 py-3 text-sm text-gray-600">Mycket hög risk</td>
								</tr>
							</tbody>
						</table>
					</div>
					<p class="mt-4 text-sm text-gray-500">
						<a href="/bmi-tabell/" class="text-brand-600 hover:text-brand-700 font-medium">Se den fullständiga BMI-tabellen →</a>
					</p>
				</div>

				<!-- Popular Calculators Grid -->
				<div class="mt-10 bg-white p-6 rounded-xl shadow-sm border border-gray-100">
					<h2 class="text-xl font-bold text-gray-900 mb-4">Populära BMI-räknare</h2>
					<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
						<a href="/bmi-kvinna/" class="p-4 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors text-center group">
							<span class="text-3xl block mb-2">👩</span>
							<p class="font-medium text-gray-900 group-hover:text-pink-700">BMI Kvinna</p>
							<p class="text-xs text-gray-500">Med åldersjustering</p>
						</a>
						<a href="/bmi-barn/" class="p-4 bg-emerald-50 rounded-lg hover:bg-emerald-100 transition-colors text-center group">
							<span class="text-3xl block mb-2">👧</span>
							<p class="font-medium text-gray-900 group-hover:text-emerald-700">BMI Barn</p>
							<p class="text-xs text-gray-500">ISO-BMI 2-18 år</p>
						</a>
						<a href="/bmi-gravid/" class="p-4 bg-rose-50 rounded-lg hover:bg-rose-100 transition-colors text-center group">
							<span class="text-3xl block mb-2">🤰</span>
							<p class="font-medium text-gray-900 group-hover:text-rose-700">BMI Gravid</p>
							<p class="text-xs text-gray-500">Viktuppgång guide</p>
						</a>
						<a href="/bmi-ozempic-krav/" class="p-4 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors text-center group">
							<span class="text-3xl block mb-2">💊</span>
							<p class="font-medium text-gray-900 group-hover:text-blue-700">Ozempic Krav</p>
							<p class="text-xs text-gray-500">BMI-gränser 2026</p>
						</a>
					</div>
				</div>

				<!-- Additional SEO Content -->
				<div class="prose prose-brand prose-lg text-gray-600 mt-12 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
					<h2>Om vår BMI-kalkylator</h2>
					<p>
						Vår kostnadsfria BMI-räknare är utvecklad för att ge dig en snabb och exakt beräkning av ditt Body Mass Index. 
												                Till skillnad från enklare verktyg tar vår kalkylator hänsyn till din
						<strong>ålder</strong>
						och
						<strong>kön</strong>, 
														                vilket ger ett mer nyanserat resultat, särskilt för
						<a href="/bmi-barn/">barn (ISO-BMI)</a>
						och
						<a href="/bmi-kvinna/">kvinnor efter ålder</a>.
					</p>
					<h3>Vad gör oss unika?</h3>
					<ul>
						<li>
							<strong>Senioranpassning:</strong>
							För personer över 65 år justeras gränsvärdena enligt aktuella rekommendationer (22-29 istället för 18.5-25).</li>
						<li>
							<strong>Midjemått:</strong>
							Du kan valfritt ange ditt midjemått för en mer komplett riskbedömning av bukfetma.</li>
						<li>
							<strong>Idealvikt:</strong>
							Vi visar din beräknade idealviktsintervall baserat på din längd.</li>
					</ul>

					<h3>BMI-historik: Från Quetelet till WHO</h3>
					<p>
						BMI-formeln utvecklades av den belgiske matematikern Adolphe Quetelet på 1830-talet och kallades ursprungligen 
												                "Quetelet Index". Det var först på 1970-talet som termen "Body Mass Index" började användas, när forskaren 
												                Ancel Keys föreslog det som ett enkelt sätt att mäta fetma i befolkningsstudier. Idag är BMI den globala 
												                standarden som används av WHO, svenska vårdguiden 1177 och läkare världen över.
					</p>

					<h3>Begränsningar med BMI</h3>
					<p>
						BMI är ett användbart screeningverktyg, men det är viktigt att komma ihåg att det inte skiljer på fett och muskelmassa. 
												                En vältränad person med mycket muskler kan klassificeras som "överviktig" trots att de har låg fettprocent. 
												                Därför rekommenderar vi att komplettera med midjemått och konsultera en läkare för en fullständig hälsobedömning.
						<a href="/bmi-formel/">Läs mer om hur BMI räknas ut</a>.
					</p>

					<h3>Relaterade verktyg</h3>
					<p>
						Utforska våra andra gratis hälsoverktyg:
					</p>
					<ul>
						<li>
							<a href="/idealvikt/">Idealvikt-räknare</a>
							– Beräkna din optimala vikt med fyra vetenskapliga formler</li>
						<li>
							<a href="/kalorier/">Kaloriräknare (TDEE)</a>
							– Räkna ut ditt dagliga kaloribehov</li>
						<li>
							<a href="/bmi-tabell/">BMI-tabell</a>
							– Se ditt BMI direkt utan att räkna</li>
					</ul>
				</div>
			</div>

		</div>
	</div>
{% endblock %}

