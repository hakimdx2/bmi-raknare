{% extends "base.twig" %}

{% block title %}Idealvikt Kalkylator: Vad är normalt BMI? (Gratis Räknare 2026){% endblock %}
{% block description %}Räkna ut din idealvikt och se vad som är normalt BMI för din längd. Vår gratis kalkylator använder 4 vetenskapliga formler för exakt resultat.{% endblock %}
{% block canonical %}{{ base_url }}/idealvikt/{% endblock %}

{% block schema %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Idealvikt Räknare",
    "url": "{{ base_url }}/idealvikt/",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Any",
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "SEK"
    },
    "description": "Kalkylator för att beräkna idealvikt baserat på längd och kön med fyra vetenskapliga formler."
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Vad är idealvikt?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Idealvikt är den vikt som statistiskt sett är förknippad med lägst hälsorisker för din längd. Det finns ingen exakt siffra, därför använder vi fyra olika vetenskapliga formler för att ge ett intervall."
            }
        },
        {
            "@type": "Question",
            "name": "Hur räknar man ut idealvikt?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Idealvikt beräknas vanligtvis med formler som Devine, Robinson, Miller eller Hamwi. Dessa formler baseras på längd och kön för att ge en uppskattning av optimal vikt."
            }
        },
        {
            "@type": "Question",
            "name": "Vad är skillnaden mellan idealvikt och normalvikt?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Idealvikt är en specifik siffra beräknad med formler, medan normalvikt avser ett BMI-intervall (18.5-25) som anses hälsosamt enligt WHO."
            }
        }
    ]
}
</script>
{% endblock %}

{% block content %}
<div class="bg-gray-50 min-h-screen">
    
    <!-- Header -->
    <div class="bg-gradient-to-r from-indigo-50 to-purple-50 border-b border-indigo-100">
        <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
            <nav class="flex text-sm text-gray-500 mb-4">
                <a href="/" class="hover:text-brand-600">Hem</a>
                <span class="mx-2">/</span>
                <span class="font-medium text-gray-900">Idealvikt</span>
            </nav>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
                <h1 class="text-2xl font-extrabold text-gray-900 sm:text-3xl lg:text-4xl">
                    Räkna ut Idealvikt & Normalt BMI
                </h1>
                <!-- Trust badge inline -->
                <div class="flex items-center mt-2 sm:mt-0 text-xs text-gray-500">
                    <svg class="h-4 w-4 text-green-500 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    Vetenskapligt baserad
                </div>
            </div>
            <p class="mt-2 text-lg text-gray-600">
                Beräkna din optimala vikt baserat på längd och kön med flera vetenskapliga formler.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <!-- Main Content -->
            <div class="lg:col-span-2">
                
                <!-- Calculator Card -->
                <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 sm:p-8 mb-8" x-data="idealWeightCalculator()">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
                        <h2 class="text-xl font-bold text-gray-900">Idealvikt Kalkylator</h2>
                        <!-- Trust badge inline -->
                        <div class="flex items-center mt-2 sm:mt-0 text-xs text-gray-500">
                            <svg class="h-4 w-4 text-green-500 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            4 formler
                        </div>
                    </div>
                    
                    <div class="space-y-6 mb-8">
                        <!-- Gender buttons like main calculator -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Kön</label>
                            <div class="grid grid-cols-2 gap-3">
                                <button type="button" @click="gender = 'female'" 
                                        :class="{'bg-pink-50 border-pink-500 text-pink-700 ring-2 ring-pink-200': gender === 'female', 'bg-white border-gray-300 text-gray-700 hover:border-gray-400': gender !== 'female'}" 
                                        class="border-2 rounded-xl py-4 px-4 flex items-center justify-center text-sm font-semibold shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-all duration-200">
                                    <svg class="w-5 h-5 mr-2" :class="gender === 'female' ? 'text-pink-500' : 'text-gray-400'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                                    Kvinna
                                </button>
                                <button type="button" @click="gender = 'male'" 
                                        :class="{'bg-blue-50 border-blue-500 text-blue-700 ring-2 ring-blue-200': gender === 'male', 'bg-white border-gray-300 text-gray-700 hover:border-gray-400': gender !== 'male'}" 
                                        class="border-2 rounded-xl py-4 px-4 flex items-center justify-center text-sm font-semibold shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-all duration-200">
                                    <svg class="w-5 h-5 mr-2" :class="gender === 'male' ? 'text-blue-500' : 'text-gray-400'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                                    Man
                                </button>
                            </div>
                        </div>
                        
                        <!-- Height input like main calculator -->
                        <div>
                            <label for="height" class="block text-sm font-medium text-gray-700 mb-1">Längd</label>
                            <div class="relative rounded-xl shadow-sm">
                                <input type="number" name="height" id="height" x-model="height" 
                                       class="block w-full pl-4 pr-12 py-4 text-lg border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all duration-200 hover:border-gray-300" 
                                       placeholder="175">
                                <div class="absolute inset-y-0 right-0 pr-5 flex items-center pointer-events-none">
                                    <span class="text-gray-400 text-sm font-medium bg-gray-50 px-2 py-1 rounded">cm</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Results -->
                    <template x-if="height >= 140 && height <= 220 && gender">
                        <div class="mt-8 pt-8 border-t border-gray-100 animate-fade-in-up">
                            <div class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl p-6 sm:p-8 border border-indigo-100">
                                <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
                                    <svg class="w-6 h-6 text-indigo-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    Din Idealvikt
                                </h3>
                                
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                                    <div class="bg-white rounded-xl p-4 text-center shadow-sm border border-gray-100 transform transition-transform hover:-translate-y-1">
                                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Devine</div>
                                        <div class="text-2xl font-extrabold text-indigo-600" x-text="devine()"></div>
                                        <div class="text-xs text-gray-400 mt-1">kg</div>
                                    </div>
                                    <div class="bg-white rounded-xl p-4 text-center shadow-sm border border-gray-100 transform transition-transform hover:-translate-y-1">
                                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Robinson</div>
                                        <div class="text-2xl font-extrabold text-indigo-600" x-text="robinson()"></div>
                                        <div class="text-xs text-gray-400 mt-1">kg</div>
                                    </div>
                                    <div class="bg-white rounded-xl p-4 text-center shadow-sm border border-gray-100 transform transition-transform hover:-translate-y-1">
                                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Miller</div>
                                        <div class="text-2xl font-extrabold text-indigo-600" x-text="miller()"></div>
                                        <div class="text-xs text-gray-400 mt-1">kg</div>
                                    </div>
                                    <div class="bg-white rounded-xl p-4 text-center shadow-sm border border-gray-100 transform transition-transform hover:-translate-y-1">
                                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Hamwi</div>
                                        <div class="text-xl font-extrabold text-indigo-600" x-text="hamwi()"></div>
                                        <div class="text-xs text-gray-400 mt-1">kg</div>
                                    </div>
                                </div>

                                <!-- Summary Cards -->
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    <div class="bg-white rounded-xl p-8 shadow-sm border-l-8 border-green-500">
                                        <div class="text-sm font-medium text-gray-500 mb-2">Hälsosamt BMI-intervall</div>
                                        <div class="text-3xl font-bold text-gray-900 mb-1" x-text="bmiRange()"></div>
                                        <div class="text-sm text-green-600 font-medium flex items-center">
                                            <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                            Rekommenderat av WHO
                                        </div>
                                    </div>
                                    <div class="bg-white rounded-xl p-8 shadow-sm border-l-8 border-indigo-500">
                                        <div class="text-sm font-medium text-gray-500 mb-2">Genomsnittlig idealvikt</div>
                                        <div class="text-3xl font-bold text-gray-900 mb-1" x-text="average() + ' kg'"></div>
                                        <div class="text-sm text-indigo-600 font-medium flex items-center">
                                            <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                            Baserat på 4 formler
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </template>

                    <template x-if="!height || !gender">
                        <div class="mt-8 bg-gray-50 rounded-xl p-8 text-center border border-gray-200">
                            <svg class="h-12 w-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                            </svg>
                            <p class="text-gray-500">Ange din längd och välj kön för att se din idealvikt</p>
                        </div>
                    </template>
                </div>

                <!-- Content Area -->
                <div class="prose prose-brand prose-lg text-gray-600 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
                    <h2>Vad är idealvikt?</h2>
                    <p>
                        Idealvikt är den vikt som statistiskt sett är förknippad med lägst hälsorisker för din längd. 
                        Det finns inga exakta siffror – därför visar vår kalkylator resultat från <strong>fyra olika vetenskapliga formler</strong>.
                    </p>

                    <h3>Formlerna vi använder</h3>
                    <ul>
                        <li><strong>Devine (1974):</strong> Den mest använda formeln inom medicin, särskilt för läkemedelsdosering.</li>
                        <li><strong>Robinson (1983):</strong> En modifierad version av Devine med bättre träffsäkerhet för normalbyggda.</li>
                        <li><strong>Miller (1983):</strong> Ger ofta lägre värden och passar bättre för smalare kroppstyper.</li>
                        <li><strong>Hamwi (1964):</strong> En av de äldsta formlerna, fortfarande populär i klinisk praxis.</li>
                    </ul>

                    <h3>Hur beräknas idealvikt?</h3>
                    <p>
                        Alla formler utgår från en baslinjevikt vid 152.4 cm (5 fot) och lägger till en viss vikt för varje ytterligare 
                        centimeter. Kön påverkar beräkningen eftersom män och kvinnor har olika genomsnittlig kroppssammansättning.
                    </p>

                    <h3>Idealvikt vs Normalvikt</h3>
                    <p>
                        Det är viktigt att skilja på idealvikt och normalvikt. <strong>Idealvikt</strong> är en specifik siffra 
                        beräknad med formler, medan <strong>normalvikt</strong> avser ett BMI-intervall (18.5-25) som anses hälsosamt 
                        enligt WHO. Båda har sina fördelar – idealvikt ger ett exakt mål, medan normalvikt tillåter mer flexibilitet.
                    </p>

                    <h3>Viktigt att tänka på</h3>
                    <p>
                        Idealvikt tar inte hänsyn till muskelmassa, benstruktur eller individuella faktorer. 
                        En person med mycket muskler kan ha en "hög" vikt utan att vara ohälsosam.
                    </p>
                    <p>
                        Vår <a href="/">BMI-räknare</a> ger en mer komplett bild genom att även inkludera ålder och midjemått.
                        Du kan också kolla vår <a href="/bmi-tabell/">BMI-tabell</a> för en snabb överblick.
                    </p>
                </div>
            </div>

            <!-- Sidebar -->
            {% include 'components/sidebar.twig' %}

        </div>
    </div>
</div>

<script>
function idealWeightCalculator() {
    return {
        height: '',
        gender: '',
        
        // Convert height to inches for formulas
        inches() {
            return (this.height - 152.4) / 2.54;
        },
        
        // Devine formula (1974)
        devine() {
            const i = this.inches();
            if (i < 0) return this.gender === 'male' ? 50 : 45.5;
            return this.gender === 'male'
                ? (50 + 2.3 * i).toFixed(1)
                : (45.5 + 2.3 * i).toFixed(1);
        },
        
        // Robinson formula (1983)
        robinson() {
            const i = this.inches();
            if (i < 0) return this.gender === 'male' ? 52 : 49;
            return this.gender === 'male'
                ? (52 + 1.9 * i).toFixed(1)
                : (49 + 1.7 * i).toFixed(1);
        },
        
        // Miller formula (1983)
        miller() {
            const i = this.inches();
            if (i < 0) return this.gender === 'male' ? 56.2 : 53.1;
            return this.gender === 'male'
                ? (56.2 + 1.41 * i).toFixed(1)
                : (53.1 + 1.36 * i).toFixed(1);
        },
        
        // Hamwi formula (1964)
        hamwi() {
            const i = this.inches();
            if (i < 0) return this.gender === 'male' ? 48 : 45.5;
            return this.gender === 'male'
                ? (48 + 2.7 * i).toFixed(1)
                : (45.5 + 2.2 * i).toFixed(1);
        },
        
        // Average of all formulas
        average() {
            const avg = (parseFloat(this.devine()) + parseFloat(this.robinson()) + parseFloat(this.miller()) + parseFloat(this.hamwi())) / 4;
            return avg.toFixed(1);
        },
        
        // BMI-based healthy weight range
        bmiRange() {
            const h = this.height / 100;
            const min = (18.5 * h * h).toFixed(0);
            const max = (25 * h * h).toFixed(0);
            return min + ' – ' + max + ' kg';
        }
    }
}
</script>
{% endblock %}
