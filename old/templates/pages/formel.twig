{% extends "base.twig" %}

{% block title %}Hur räknar man ut BMI? - BMI Formel & Exempel (2026){% endblock %}
{% block description %}Undrar du hur man räknar ut BMI? Här är formeln och enkla räkneexempel. Lär dig beräkna ditt Body Mass Index manuellt med vår guide.{% endblock %}
{% block canonical %}{{ base_url }}/bmi-formel/{% endblock %}

{% block schema %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Hur räknar man ut BMI? - Formel och Exempel",
    "author": {
        "@type": "Organization",
        "name": "BMI-Räknare.se"
    },
    "datePublished": "2024-01-15",
    "dateModified": "2026-01-01",
    "description": "En djupgående guide till matematiken bakom Body Mass Index, med steg-för-steg exempel."
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "Så räknar du ut ditt BMI manuellt",
    "step": [
        {
            "@type": "HowToStep",
            "name": "Mät din längd",
            "text": "Mät din längd i meter (t.ex. 1.75 m)."
        },
        {
            "@type": "HowToStep",
            "name": "Väg dig",
            "text": "Väg dig i kilogram (t.ex. 70 kg)."
        },
        {
            "@type": "HowToStep",
            "name": "Kvadrera längden",
            "text": "Multiplicera din längd med sig själv (1.75 * 1.75 = 3.0625)."
        },
        {
            "@type": "HowToStep",
            "name": "Dividera",
            "text": "Dela din vikt med den kvadrerade längden (70 / 3.0625 = 22.8)."
        }
    ]
}
</script>
{% endblock %}

{% block content %}
<div class="bg-gray-50 min-h-screen">
    
    <!-- Premium Header -->
    <div class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
            <nav class="flex text-sm text-gray-500 mb-4">
                <a href="/" class="hover:text-brand-600 transition-colors">Hem</a>
                <span class="mx-2">/</span>
                <span class="font-medium text-gray-900">BMI Formel</span>
            </nav>
            <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl tracking-tight">
                        Hur räknar man ut BMI? (Formel & Exempel)
                    </h1>
                    <p class="mt-3 text-lg text-gray-500 max-w-2xl">
                        Den matematiska sanningen bakom världens mest använda hälsomått. Lär dig räkna ut det själv.
                    </p>
                </div>
                <!-- Trust Badge -->
                <div class="mt-4 md:mt-0 flex items-center bg-blue-50 px-4 py-2 rounded-full border border-blue-100">
                    <svg class="h-5 w-5 text-blue-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    <span class="text-sm font-medium text-blue-800">Quetelet's Index</span>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <!-- Main Content -->
            <div class="lg:col-span-2">
                <article class="prose prose-brand prose-lg text-gray-600 bg-white p-8 sm:p-12 rounded-2xl shadow-sm border border-gray-100">
                    
                    <!-- Visual Formula Card -->
                    <div class="not-prose bg-gradient-to-br from-brand-50 to-blue-50 rounded-2xl p-10 sm:p-12 border border-brand-100 mb-12 text-center transform transition-all hover:shadow-lg duration-300">
                        <h2 class="text-sm font-bold text-gray-500 uppercase tracking-widest mb-6">Officiell BMI Ekvation</h2>
                        <div class="flex items-center justify-center gap-8 text-4xl sm:text-5xl font-black text-gray-900 font-mono">
                            <span class="text-brand-900">BMI</span>
                            <span class="text-brand-300">=</span>
                            <div class="flex flex-col items-center group cursor-default">
                                <span class="border-b-4 border-gray-900 pb-2 px-4 group-hover:border-brand-600 transition-colors">Vikt <span class="text-lg text-gray-500 font-sans font-normal">(kg)</span></span>
                                <span class="pt-2 px-4">Längd <span class="text-lg text-gray-500 font-sans font-normal">(m)²</span></span>
                            </div>
                        </div>
                        <p class="mt-6 text-base text-gray-600 font-medium bg-white/50 inline-block px-4 py-2 rounded-full border border-brand-50">
                            Vikten dividerat med längden i kvadrat
                        </p>
                    </div>

                    <h2 class="flex items-center text-brand-900">
                        <span class="bg-brand-100 p-2 rounded-lg mr-3">
                            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                        </span>
                        Den matematiska förklaringen
                    </h2>
                    <p>
                        BMI (Body Mass Index) är ett mått som uppfanns av den belgiske matematikern Adolphe Quetelet på 1830-talet. 
                        Hans mål var inte att mäta fetma, utan att hitta "genomsnittsmänniskan". Formeln är bedrägligt enkel men 
                        matematiskt elegant eftersom den korrelerar vikt med kroppsyta.
                    </p>
                    <p>
                        Enheten för BMI är egentligen <strong>kg/m²</strong>, men i dagligt tal utelämnar vi oftast enheten och säger 
                        bara siffran, till exempel "24".
                    </p>

                    <h3>Steg-för-steg Räkneexempel</h3>
                    <p>Låt oss räkna ut BMI för <strong>Johan</strong>:</p>
                    <div class="not-prose bg-gray-50 p-8 rounded-2xl border border-gray-200 space-y-4 my-8">
                        <div class="flex items-center text-lg text-gray-800">
                            <span class="flex-shrink-0 h-10 w-10 bg-white rounded-full border border-gray-200 flex items-center justify-center mr-4 shadow-sm text-green-500">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
                            </span>
                            <span>Johan väger&nbsp;<strong>85 kg</strong></span>
                        </div>
                        <div class="flex items-center text-lg text-gray-800">
                             <span class="flex-shrink-0 h-10 w-10 bg-white rounded-full border border-gray-200 flex items-center justify-center mr-4 shadow-sm text-blue-500">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
                            </span>
                            <span>Han är&nbsp;<strong>182 cm</strong>&nbsp;lång (1.82 m)</span>
                        </div>
                    </div>
                    
                    <ol>
                        <li>
                            <strong>Omvandla längden till meter:</strong><br>
                            182 cm = 1.82 m
                        </li>
                        <li>
                            <strong>Kvadrera längden (ta den gånger sig själv):</strong><br>
                            <code>1.82 × 1.82 = 3.3124</code>
                        </li>
                        <li>
                            <strong>Dividera vikten med resultatet:</strong><br>
                            <code>85 ÷ 3.3124 ≈ 25.66</code>
                        </li>
                    </ol>
                    
                    <div class="bg-blue-50 border-l-4 border-blue-500 p-4 my-6">
                        <p class="text-blue-900 m-0 font-medium">
                            <strong>Resultat:</strong> Johans BMI är <strong>25.7</strong>. Enligt WHO klassas detta precis över gränsen till <span class="font-bold">Övervikt</span> (som börjar vid 25).
                        </p>
                    </div>

                    <h2 class="flex items-center text-brand-900 mt-12">
                         <span class="bg-brand-100 p-2 rounded-lg mr-3">
                            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </span>
                        Varför "Längd i kvadrat"?
                    </h2>
                    <p>
                        Många undrar varför man inte bara delar vikten med längden. Svaret ligger i geometri. 
                        Tänk dig en människa som en cylinder (förenklat). Om du gör en cylinder dubbelt så hög men behåller samma 
                        proportioner, blir den inte dubbelt så tung – den blir <strong>kuben</strong> av höjden tyngre.
                    </p>
                    <p>
                        Men människor växer inte proportionerligt i bredd när de växer på längden. Quetelet upptäckte att vikten 
                        hos vuxna ökar ungefär i takt med <em>kvadraten</em> på längden, inte kuben eller linjärt. Därför ger m² 
                        den bästa korrelationen mot kroppsfett oberoende av hur lång du är.
                    </p>

                    <h2 class="flex items-center text-brand-900 mt-12">
                         <span class="bg-brand-100 p-2 rounded-lg mr-3">
                            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                        </span>
                        Nick Trefethens Nya Formel (BMI 2.0)
                    </h2>
                    <p>
                        2013 föreslog matematikprofessorn Nick Trefethen vid Oxford University en uppdaterad formel. Han menade att den 
                        gamla formeln får korta personer att verka smalare än de är, och långa personer att verka tjockare.
                    </p>
                    <p>Bara för kännedom (standardvården använder fortfarande den gamla), här är den nya formeln:</p>
                    <div class="bg-gray-800 text-gray-200 p-4 rounded-lg font-mono text-sm">
                        1.3 × Vikt / Längd^2.5
                    </div>
                    <p class="text-sm text-gray-500 mt-2">
                        <em>Obs: Vår kalkylator använder den officiella standardformeln (Quetelet) som används av sjukvården i Sverige och WHO.</em>
                    </p>

                    <h3>Begränsningar i formeln</h3>
                    <p>
                        Matematik kan inte se skillnad på fett och muskler. En bodybuilder med 100 kg muskler kommer få samma BMI 
                        som en person med 100 kg fett, om de är lika långa. Därför ska BMI alltid ses som en screening, inte en diagnos.
                    </p>

                    <div class="not-prose mt-10 p-8 bg-brand-50 rounded-2xl border border-brand-100 flex flex-col sm:flex-row items-center justify-between gap-6 shadow-sm">
                        <div class="text-center sm:text-left">
                            <h4 class="text-brand-900 font-bold text-lg m-0 mb-1">Slipp huvudräkningen!</h4>
                            <p class="text-brand-700 text-sm m-0">Använd vårt automatiserade verktyg istället.</p>
                        </div>
                        <a href="/" class="flex-shrink-0 inline-flex items-center justify-center px-6 py-4 border border-transparent text-base font-bold rounded-xl text-white bg-brand-600 hover:bg-brand-700 shadow-md transform hover:-translate-y-1 transition-all duration-200">
                            Öppna Räknaren
                            <svg class="ml-2 -mr-1 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </a>
                    </div>

                </article>
            </div>

            <!-- Sidebar -->
            {% include 'components/sidebar.twig' %}

        </div>
    </div>
</div>
{% endblock %}
