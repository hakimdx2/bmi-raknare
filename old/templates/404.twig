{% extends "base.twig" %}

{% block title %}Sidan hittades inte (404) | bmi-raknare.se{% endblock %}
{% block description %}Ojdå! Sidan du letar efter verkar inte finnas. Här hittar du våra mest populära verktyg istället.{% endblock %}

{% block content %}
<div class="bg-gray-50 min-h-screen flex items-center justify-center px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="max-w-2xl w-full text-center">
        <!-- 404 Illustration placeholder or Icon -->
        <div class="mb-8">
            <span class="inline-block p-4 rounded-full bg-blue-50 border border-blue-100">
                <svg class="h-16 w-16 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </span>
        </div>
        
        <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight sm:text-5xl">
            Sidan hittades inte
        </h1>
        <p class="mt-4 text-xl text-gray-500">
            Vi kunde tyvärr inte hitta sidan du letade efter. Kanske har den flyttat eller så skrev du fel adress.
        </p>

        <!-- Tool Grid -->
        <div class="mt-12">
            <h2 class="text-sm font-semibold text-gray-400 tracking-wide uppercase mb-6">Populära Verktyg</h2>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <!-- BMI -->
                <a href="/" class="group relative rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-blue-300 transition-all">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 bg-blue-100 rounded-lg p-3 group-hover:bg-blue-600 transition-colors">
                            <svg class="h-6 w-6 text-blue-600 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                            </svg>
                        </div>
                        <div class="ml-4 text-left">
                            <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600">BMI Räknare</h3>
                            <p class="text-sm text-gray-500">Kontrollera din viktstatus</p>
                        </div>
                    </div>
                </a>

                <!-- Kalorier -->
                <a href="/kalorier/" class="group relative rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-green-300 transition-all">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 bg-green-100 rounded-lg p-3 group-hover:bg-green-600 transition-colors">
                            <svg class="h-6 w-6 text-green-600 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div class="ml-4 text-left">
                            <h3 class="text-lg font-bold text-gray-900 group-hover:text-green-600">Kaloriräknare</h3>
                            <p class="text-sm text-gray-500">Beräkna dagsbehov (TDEE)</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <div class="mt-12">
            <a href="/" class="text-base font-medium text-brand-600 hover:text-brand-500">
                Gå till startsidan <span aria-hidden="true">&rarr;</span>
            </a>
        </div>
    </div>
</div>
{% endblock %}
