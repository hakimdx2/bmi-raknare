{% extends "base.twig" %}

{% set segment_data = {
    'kvinna': {
        'color': 'pink',
        'title': 'BMI Kvinna & Ålder: Räkna ut BMI för Kvinnor (Kalkylator 2026)',
        'description': 'Räkna ut BMI för kvinna med vår anpassade kalkylator som tar hänsyn till ålder. Se tabell och tolka ditt resultat. Gratis verktyg!',
        'h1': 'BMI Kvinna – Räkna ut BMI',
        'intro': 'Kvinnor har naturligt en något högre fettprocent än män. Vår kalkylator tar hänsyn till din ålder för att ge dig ett korrekt BMI-värde.',
        'plural': 'kvinnor'
    },
    'man': {
        'color': 'blue',
        'title': 'BMI Man & Ålder: Räkna ut BMI för Män (Tabell 2026)',
        'description': 'Räkna ut BMI för män med vår anpassade kalkylator. Tar hänsyn till muskelmassa och ålder. Se BMI-tabell för män här. Gratis!',
        'h1': 'BMI Man – Räkna ut BMI',
        'intro': 'Män har ofta mer muskelmassa vilket kan påverka BMI. Vår kalkylator ger dig en korrekt uträkning och tolkning anpassad för män.',
        'plural': 'män'
    },
    'barn': {
        'color': 'emerald',
        'title': 'BMI Barn & Ungdom: ISO-BMI Räknare (2 till 18 år)',
        'description': 'Beräkna BMI för barn och ungdomar med vår ISO-BMI räknare. Vi följer BVC:s kurvor för ålder och kön. Gratis och exakt.',
        'h1': 'BMI Barn (ISO-BMI Kalkylator)',
        'intro': 'För barn används ISO-BMI som tar hänsyn till att barn växer olika beroende på ålder och kön. Detta är standarden som används av vården.',
        'plural': 'barn'
    }
} %}

{% set data = segment_data[segment] %}

{% block title %}{{ data.title }}{% endblock %}
{% block description %}{{ data.description }}{% endblock %}
{% block canonical %}{{ base_url }}/bmi-{{ segment }}/{% endblock %}

{% block schema %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "BMI Räknare för {{ segment|capitalize }}",
    "url": "{{ base_url }}/bmi-{{ segment }}/",
    "description": "{{ data.description }}",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "All",
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "SEK"
    }
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Vad är normalt BMI för {{ data.plural }}?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ett normalt BMI för vuxna {{ data.plural }} ligger mellan 18.5 och 25. Detta intervall anses hälsosamt enligt WHO och svenska vårdguiden 1177."
            }
        },
        {
            "@type": "Question", 
            "name": "Hur beräknar man BMI för {{ data.plural }}?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "BMI beräknas genom att dividera vikten i kilogram med längden i meter i kvadrat. Formeln är: BMI = vikt (kg) / (längd (m) × längd (m))."
            }
        }
    ]
}
</script>
{% endblock %}

{% block content %}
<div class="bg-gray-50 min-h-screen">
    
    <!-- Header / Breadcrumb -->
    <div class="bg-gradient-to-r from-{{ data.color }}-50 to-{{ data.color }}-100 border-b border-{{ data.color }}-200">
        <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
            <nav class="flex text-sm text-gray-500 mb-4" aria-label="Breadcrumb">
                <a href="/" class="hover:text-brand-600">Hem</a>
                <span class="mx-2">/</span>
                <span class="font-medium text-gray-900">{{ segment|capitalize }}</span>
            </nav>
            <div class="flex items-center space-x-3">
                <span class="w-3 h-3 rounded-full bg-{{ data.color }}-500"></span>
                <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
                    {{ data.h1 }}
                </h1>
            </div>
            <p class="mt-3 text-lg text-gray-600 max-w-3xl">
                {{ data.intro }}
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <!-- Main Content: Calculator & Article -->
            <div class="lg:col-span-2">
                <!-- Calculator Card -->
                <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 sm:p-8 mb-12">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
                        <h2 class="text-xl font-bold text-gray-900">Beräkna ditt BMI här</h2>
                        <!-- Trust badge inline -->
                        <div class="flex items-center mt-2 sm:mt-0 text-xs text-gray-500">
                            <svg class="h-4 w-4 text-green-500 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            Medicinskt granskad
                        </div>
                    </div>
                    {% include 'components/calculator.twig' %}
                    
                    {% include 'components/medical-review.twig' %}
                </div>

                <!-- Monetization CTA -->
                {% include 'components/cta-box.twig' %}

                <!-- Content Area -->
                <div class="prose prose-brand prose-lg text-gray-600 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
                    <h2>Vad är normalt BMI för {{ data.plural }}?</h2>
                    <p>
                        Att förstå sitt BMI är viktigt för att få en snabb indikation på sin viktstatus. 
                        {{ data.intro }}
                    </p>
                    
                    <p>
                        Enligt Världshälsoorganisationen (WHO) och svenska 1177 Vårdguiden anses ett BMI mellan 
                        <strong>18.5 och 25</strong> vara normalvikt för vuxna. För äldre personer (65+) rekommenderas 
                        ofta ett något högre intervall på 22-29.
                    </p>

                    <h3>BMI-tabell för {{ data.plural }}</h3>
                    <div class="not-prose mt-4 mb-6">
                        <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
                            <table class="min-w-full divide-y divide-gray-300">
                                <thead class="bg-{{ data.color }}-50">
                                    <tr>
                                        <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900">Klassificering</th>
                                        <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">BMI-intervall</th>
                                        <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Betydelse</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200 bg-white">
                                    <tr>
                                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">Undervikt</td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">&lt; 18.5</td>
                                        <td class="px-3 py-4 text-sm text-blue-600">Kan tyda på undernäring</td>
                                    </tr>
                                    <tr class="bg-green-50">
                                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-green-800">Normalvikt</td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-green-700 font-semibold">18.5 – 25.0</td>
                                        <td class="px-3 py-4 text-sm text-green-700">Hälsosamt viktintervall</td>
                                    </tr>
                                    <tr>
                                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">Övervikt</td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">25.0 – 30.0</td>
                                        <td class="px-3 py-4 text-sm text-orange-600">Ökad risk för hälsoproblem</td>
                                    </tr>
                                    <tr>
                                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">Fetma klass I</td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">30.0 – 35.0</td>
                                        <td class="px-3 py-4 text-sm text-red-600">Hög risk för hälsoproblem</td>
                                    </tr>
                                    <tr>
                                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">Fetma klass II+</td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">&gt; 35.0</td>
                                        <td class="px-3 py-4 text-sm text-red-700">Mycket hög risk</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <h3>Ålderns betydelse för {{ data.plural }}</h3>
                    <p>
                        Ju äldre man blir, desto mer förändras kroppens sammansättning. Muskelmassa minskar naturligt 
                        med åldern medan fettandelen ökar, även om vikten är oförändrad. Det är därför som äldre 
                        personer (65+) ofta rekommenderas ett något högre BMI.
                    </p>

                    {% if segment == 'kvinna' %}
                    <h3>Speciella överväganden för kvinnor</h3>
                    <p>
                        Kvinnor genomgår hormonella förändringar genom livet som kan påverka vikten – menstruationscykel, 
                        graviditet och klimakteriet har alla inverkan. Under graviditeten bör du <strong>inte</strong> 
                        använda vanliga BMI-gränsvärden. Läs mer på vår <a href="/bmi-gravid/">sida för gravida</a>.
                    </p>
                    
                    <h3>WHO:s rekommendationer för kvinnor</h3>
                    <p>
                        Enligt Världshälsoorganisationen (WHO) bör vuxna kvinnor sträva efter ett BMI mellan 18.5 och 24.9 
                        för optimal hälsa. Ett BMI under 18.5 kan öka risken för näringsbrist, benskörhet och 
                        menstruationsstörningar. Ett BMI över 25 ökar risken för hjärt-kärlsjukdomar, typ 2-diabetes 
                        och vissa cancerformer.
                    </p>
                    
                    <h3>Midjemått för kvinnor</h3>
                    <p>
                        Förutom BMI rekommenderar 1177 Vårdguiden att kvinnor mäter sitt midjemått. Ett midjemått 
                        över <strong>80 cm</strong> indikerar ökad hälsorisk, och över <strong>88 cm</strong> 
                        innebär kraftigt ökad risk för metabola sjukdomar. Du kan mäta ditt midjemått i vår kalkylator ovan.
                    </p>
                    
                    <h3>Tips för att nå en hälsosam vikt</h3>
                    <ul>
                        <li>Ät en balanserad kost rik på grönsaker, frukt och fullkorn</li>
                        <li>Rör på dig minst 150 minuter per vecka enligt Folkhälsomyndigheten</li>
                        <li>Sov 7-9 timmar per natt för optimal hormonbalans</li>
                        <li>Hantera stress som kan leda till viktuppgång</li>
                    </ul>
                    {% elseif segment == 'man' %}
                    <h3>Speciella överväganden för män</h3>
                    <p>
                        Män som styrketränar regelbundet kan ha ett "överviktigt" BMI trots låg fettprocent. 
                        BMI skiljer inte på fett och muskler, så för aktiva män rekommenderar vi att även mäta 
                        midjemåttet. Ett midjemått under 94 cm anses hälsosamt för män.
                    </p>
                    
                    <h3>WHO:s rekommendationer för män</h3>
                    <p>
                        Enligt Världshälsoorganisationen (WHO) bör vuxna män sträva efter ett BMI mellan 18.5 och 24.9 
                        för optimal hälsa. Män med BMI över 25 har ökad risk för hjärt-kärlsjukdomar, högt blodtryck, 
                        typ 2-diabetes och sömnapné. Ett BMI under 18.5 kan indikera undernäring eller underliggande 
                        hälsoproblem.
                    </p>
                    
                    <h3>Midjemått för män</h3>
                    <p>
                        1177 Vårdguiden och WHO rekommenderar att män kompletterar BMI-mätningen med midjemått. 
                        Ett midjemått över <strong>94 cm</strong> indikerar ökad hälsorisk, och över <strong>102 cm</strong> 
                        innebär betydligt förhöjd risk för metabola sjukdomar, hjärtsjukdom och diabetes. 
                        Använd vår kalkylator ovan för att mäta ditt midjemått.
                    </p>
                    
                    <h3>Muskelmassa och BMI</h3>
                    <p>
                        Män har generellt högre andel muskelmassa än kvinnor, vilket kan ge ett missvisande högt BMI. 
                        Om du tränar regelbundet med vikter kan ditt BMI klassificeras som "övervikt" trots att din 
                        fettprocent är låg. I dessa fall är midjemått och eventuell kroppsfettmätning mer tillförlitliga.
                    </p>
                    
                    <h3>Tips för att nå en hälsosam vikt</h3>
                    <ul>
                        <li>Kombinera styrketräning med konditionsträning för bästa resultat</li>
                        <li>Ät proteinrik kost för att bevara muskelmassa vid viktnedgång</li>
                        <li>Begränsa alkoholintag som bidrar till bukfetma</li>
                        <li>Sov minst 7 timmar – sömnbrist påverkar testosteron och metabolism</li>
                    </ul>
                    {% else %}
                    <h3>Speciella överväganden för barn</h3>
                    <p>
                        Barn växer och utvecklas i olika takt, därför finns inga fasta BMI-gränser som för vuxna. 
                        Istället används så kallade percentiler som jämför barnet med andra i samma ålder och kön. 
                        Vår kalkylator använder ISO-BMI för att ge korrekta resultat.
                    </p>
                    
                    <h3>Vad är ISO-BMI?</h3>
                    <p>
                        ISO-BMI är ett internationellt system utvecklat av International Obesity Task Force (IOTF). 
                        Det översätter barns BMI till vuxenvärden, vilket gör det enklare att förstå om ett barn 
                        har undervikt, normalvikt eller övervikt jämfört med vuxna standarder.
                    </p>
                    
                    <h3>Percentiler och tillväxtkurvor</h3>
                    <p>
                        Barnhälsovården i Sverige använder tillväxtkurvor där barnets BMI jämförs med andra barn 
                        i samma ålder. En percentil på 50 betyder att hälften av alla barn väger mer och hälften 
                        väger mindre. BVC (Barnavårdscentralen) följer ditt barns utveckling regelbundet.
                    </p>
                    
                    <h3>Tips för barns hälsosamma vikt</h3>
                    <ul>
                        <li>Uppmuntra daglig fysisk aktivitet – minst 60 minuter för barn</li>
                        <li>Begränsa skärmtid och stillasittande</li>
                        <li>Erbjud varierad kost med mycket frukt och grönsaker</li>
                        <li>Undvik sockersötade drycker och godis i vardagen</li>
                        <li>Var en förebild genom att själv ha hälsosamma vanor</li>
                    </ul>
                    {% endif %}

                    <h3>Begränsningar med BMI</h3>
                    <p>
                        BMI är ett enkelt screeningverktyg men har sina begränsningar. Det tar inte hänsyn till:
                    </p>
                    <ul>
                        <li>Muskelmassa vs fettmassa</li>
                        <li>Var på kroppen fettet sitter</li>
                        <li>Benbyggnad och kroppsstorlek</li>
                        <li>Etniska skillnader</li>
                    </ul>
                    <p>
                        Därför erbjuder vår kalkylator även möjlighet att ange midjemått för en mer komplett bild 
                        av din hälsa. Du kan också se vår <a href="/bmi-tabell/">kompletta BMI-tabell</a> eller 
                        <a href="/idealvikt/">räkna ut din idealvikt</a>.
                    </p>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-1 space-y-8">
                <!-- BMI Räknare Links -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
