</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "BMI Räknare",
  "url": "{{ base_url }}",
  "description": "Beräkna ditt BMI gratis och direkt med vår exakta kalkylator för kvinnor, män och barn. Vi tar hänsyn till ålder och visar din idealvikt.",
  "applicationCategory": "HealthApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "SEK"
  }
}
</script>
{% endblock %}
