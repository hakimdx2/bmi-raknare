<div class="my-8 bg-gradient-to-r from-brand-600 to-brand-700 rounded-xl shadow-lg text-white overflow-hidden relative">
    <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-white opacity-10 rounded-full blur-xl"></div>
    
    <div class="px-6 py-8 md:flex md:items-center md:justify-between relative z-10">
        <div class="md:w-2/3">
            <span class="inline-block py-1 px-3 rounded-full bg-brand-800 bg-opacity-50 text-xs font-semibold tracking-wider mb-3">
                REKOMMENDERAT
            </span>
            <h3 class="text-2xl font-bold">
                {% if segment == 'kvinna' or segment == 'bmi-gravid' %}
                    Vill du ha en hälsosammare livsstil?
                {% elseif segment == 'man' %}
                    Bygg muskler och bränn fett effektivt
                {% else %}
                    Få hjälp att nå din målvikt
                {% endif %}
            </h3>
            <p class="mt-2 text-brand-100 text-sm md:text-base">
                Få ett skräddarsytt kost- och träningsschema baserat på ditt BMI-resultat. Prova gratis i 7 dagar.
            </p>
        </div>
        <div class="mt-6 md:mt-0 md:w-1/3 flex justify-center md:justify-end">
             <a href="/bmi-ozempic-krav/" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-brand-700 bg-white hover:bg-brand-50 shadow-sm transition-transform transform hover:-translate-y-1">
                Starta Nu &rarr;
            </a>
        </div>
    </div>
</div>
