{% extends "base.twig" %}

{% block title %}Kaloriräknare: Hur många kalorier per dag? (TDEE Kalkylator){% endblock %}
{% block description %}Räkna ut ditt dagliga kaloribehov för att gå ner i vikt eller bygga muskler. Vår gratis kaloriräknare (TDEE) visar exakt hur många kalorier du ska äta.{% endblock %}
{% block canonical %}{{ base_url }}/kalorier/{% endblock %}

{% block schema %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kaloribehov Kalkylator (TDEE)",
    "url": "{{ base_url }}/kalorier/",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Any",
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "SEK"
    },
    "description": "Kalkylator för att beräkna dagligt kaloribehov (TDEE) baserat på Mifflin-St Jeor-ekvationen, anpassad för viktminskning, viktökning eller underhåll."
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Hur många kalorier ska jag äta för att gå ner i vikt?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "För en hälsosam viktnedgång på ca 0.5 kg i veckan rekommenderas ett underskott på 500 kcal per dag från ditt totala energibehov (TDEE)."
            }
        },
        {
            "@type": "Question",
            "name": "Vilken formel är bäst för kaloribehov?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Mifflin-St Jeor-ekvationen anses vara den mest tillförlitliga standardformeln för att beräkna basalmetabolism (BMR) och totalt energibehov idag."
            }
        },
        {
            "@type": "Question",
            "name": "Vad är TDEE?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "TDEE står för Total Daily Energy Expenditure och är den totala mängd kalorier din kropp förbränner under en dag, inklusive träning och vardagsaktiviteter."
            }
        }
    ]
}
</script>
{% endblock %}

{% block content %}
<div class="bg-gray-50 min-h-screen">
    
    <!-- Header -->
    <div class="bg-gradient-to-r from-orange-50 to-red-50 border-b border-orange-100">
        <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
            <nav class="flex text-sm text-gray-500 mb-4">
                <a href="/" class="hover:text-brand-600">Hem</a>
                <span class="mx-2">/</span>
                <span class="font-medium text-gray-900">Kalorier per Dag</span>
            </nav>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
                <h1 class="text-2xl font-extrabold text-gray-900 sm:text-3xl lg:text-4xl">
                    Kaloriräknare & Beräkna Kaloribehov
                </h1>
                <!-- Trust badge inline -->
                <div class="flex items-center mt-2 sm:mt-0 text-xs text-gray-500">
                    <svg class="h-4 w-4 text-green-500 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    Mifflin-St Jeor metod
                </div>
            </div>
            <p class="mt-2 text-lg text-gray-600">
                Få reda på exakt hur många kalorier du förbränner och hur mycket du bör äta för att nå din målvikt.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <!-- Main Content -->
            <div class="lg:col-span-2">
                
                <!-- Calculator Card -->
                <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 sm:p-8 mb-8" x-data="tdeeCalculator()">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
                        <h2 class="text-xl font-bold text-gray-900">Kalorikalkylator</h2>
                        <!-- Trust badge inline -->
                        <div class="flex items-center mt-2 sm:mt-0 text-xs text-gray-500">
                            <svg class="h-4 w-4 text-green-500 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            Verifierad formel
                        </div>
                    </div>
                    
                    <div class="space-y-6 mb-8">
                        <!-- Gender buttons -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Kön</label>
                            <div class="grid grid-cols-2 gap-3">
                                <button type="button" @click="gender = 'female'" 
                                        :class="{'bg-pink-50 border-pink-500 text-pink-700 ring-2 ring-pink-200': gender === 'female', 'bg-white border-gray-300 text-gray-700 hover:border-gray-400': gender !== 'female'}" 
                                        class="border-2 rounded-xl py-4 px-4 flex items-center justify-center text-sm font-semibold shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-all duration-200">
                                    <svg class="w-5 h-5 mr-2" :class="gender === 'female' ? 'text-pink-500' : 'text-gray-400'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                                    Kvinna
                                </button>
                                <button type="button" @click="gender = 'male'" 
                                        :class="{'bg-blue-50 border-blue-500 text-blue-700 ring-2 ring-blue-200': gender === 'male', 'bg-white border-gray-300 text-gray-700 hover:border-gray-400': gender !== 'male'}" 
                                        class="border-2 rounded-xl py-4 px-4 flex items-center justify-center text-sm font-semibold shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-all duration-200">
                                    <svg class="w-5 h-5 mr-2" :class="gender === 'male' ? 'text-blue-500' : 'text-gray-400'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                                    Man
                                </button>
                            </div>
                        </div>

                        <!-- Age, Weight, Height -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Ålder</label>
                                <div class="relative rounded-xl shadow-sm">
                                    <input type="number" x-model="age" 
                                           class="block w-full pl-4 pr-14 py-4 text-lg border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all duration-200 hover:border-gray-300"
                                           placeholder="35">
                                    <div class="absolute inset-y-0 right-0 pr-5 flex items-center pointer-events-none">
                                        <span class="text-gray-400 text-sm font-medium bg-gray-50 px-3 py-1 rounded-md">år</span>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Vikt</label>
                                <div class="relative rounded-xl shadow-sm">
                                    <input type="number" x-model="weight" 
                                           class="block w-full pl-4 pr-14 py-4 text-lg border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all duration-200 hover:border-gray-300"
                                           placeholder="75">
                                    <div class="absolute inset-y-0 right-0 pr-5 flex items-center pointer-events-none">
                                        <span class="text-gray-400 text-sm font-medium bg-gray-50 px-3 py-1 rounded-md">kg</span>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Längd</label>
                                <div class="relative rounded-xl shadow-sm">
                                    <input type="number" x-model="height" 
                                           class="block w-full pl-4 pr-14 py-4 text-lg border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-all duration-200 hover:border-gray-300"
                                           placeholder="175">
                                    <div class="absolute inset-y-0 right-0 pr-5 flex items-center pointer-events-none">
                                        <span class="text-gray-400 text-sm font-medium bg-gray-50 px-3 py-1 rounded-md">cm</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Activity Level -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-3">Aktivitetsnivå</label>
                            <div class="space-y-3">
                                <template x-for="level in activityLevels" :key="level.value">
                                    <label class="flex items-center p-4 border-2 rounded-xl cursor-pointer transition-all duration-200 group" 
                                           :class="activity === level.value ? 'border-orange-500 bg-orange-50 ring-1 ring-orange-200' : 'border-gray-200 hover:border-gray-300 hover:bg-gray-50'">
                                        <input type="radio" x-model.number="activity" :value="level.value" class="sr-only">
                                        <div class="flex-1">
                                            <div class="flex items-center justify-between">
                                                <span class="font-bold text-gray-900 group-hover:text-orange-900 transition-colors" x-text="level.label"></span>
                                                <div class="h-4 w-4 rounded-full border-2 border-gray-300 flex items-center justify-center transition-colors"
                                                     :class="activity === level.value ? 'border-orange-500 bg-orange-500' : ''">
                                                    <div class="h-1.5 w-1.5 bg-white rounded-full" x-show="activity === level.value"></div>
                                                </div>
                                            </div>
                                            <div class="text-sm text-gray-500 mt-1" x-text="level.desc"></div>
                                        </div>
                                    </label>
                                </template>
                            </div>
                        </div>
                    </div>

                    <!-- Results -->
                    <template x-if="isValid()">
                        <div class="mt-8 pt-8 border-t border-gray-100 animate-fade-in-up">
                            <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-2xl p-6 sm:p-8 border border-orange-100">
                                <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
                                    <svg class="w-6 h-6 text-orange-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                    </svg>
                                    Ditt Dagliga Energibehov (TDEE)
                                </h3>
                                
                                <div class="text-center mb-8">
                                    <div class="text-5xl font-extrabold text-orange-600 tracking-tight" x-text="tdee()"></div>
                                    <div class="text-sm font-medium text-orange-800 mt-2 uppercase tracking-wide">Kalorier per dag</div>
                                    <div class="text-xs text-gray-500 mt-2">För att behålla nuvarande vikt</div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    <!-- Weight Loss -->
                                    <div class="bg-white rounded-xl p-6 shadow-sm border-l-8 border-green-500 transform transition-transform hover:-translate-y-1">
                                        <div class="flex items-center justify-between mb-2">
                                            <span class="text-sm font-bold text-gray-500 uppercase tracking-wider">Gå ner i vikt</span>
                                            <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-1 rounded">-0.5 kg/vecka</span>
                                        </div>
                                        <div class="text-3xl font-bold text-gray-900" x-text="(parseInt(tdee()) - 500)"></div>
                                        <div class="text-sm text-green-600 mt-1 font-medium">kcal / dag</div>
                                    </div>

                                    <!-- Muscle Gain -->
                                    <div class="bg-white rounded-xl p-6 shadow-sm border-l-8 border-blue-500 transform transition-transform hover:-translate-y-1">
                                        <div class="flex items-center justify-between mb-2">
                                            <span class="text-sm font-bold text-gray-500 uppercase tracking-wider">Bygga muskler</span>
                                            <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2 py-1 rounded">Överskott</span>
                                        </div>
                                        <div class="text-3xl font-bold text-gray-900" x-text="(parseInt(tdee()) + 300)"></div>
                                        <div class="text-sm text-blue-600 mt-1 font-medium">kcal / dag</div>
                                    </div>
                                </div>
                                
                                <div class="mt-6 pt-6 border-t border-orange-100 flex justify-between items-center text-xs text-gray-500">
                                    <span>Basalmetabolism (BMR): <strong x-text="bmr()"></strong> kcal</span>
                                    <span>Formel: Mifflin-St Jeor</span>
                                </div>
                            </div>
                        </div>
                    </template>

                    <template x-if="!isValid()">
                        <div class="mt-8 bg-gray-50 rounded-xl p-8 text-center border border-gray-200">
                            <svg class="h-12 w-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
                            </svg>
                            <p class="text-gray-500">Fyll i dina uppgifter ovan för att se ditt resultat</p>
                        </div>
                    </template>
                </div>

                <!-- Content Area -->
                <div class="prose prose-brand prose-lg text-gray-600 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
                    <h2>Vad är TDEE?</h2>
                    <p>
                        TDEE (Total Daily Energy Expenditure) är det totala antalet kalorier du förbränner varje dag. Det är summan av din 
                        <strong>Basalmetabolism (BMR)</strong> – energin som krävs för att hålla kroppen igång i vila – och 
                        kalorierna du bränner genom <strong>fysisk aktivitet</strong> och matsmältning (TEF).
                    </p>

                    <h3>Varför är TDEE viktigt?</h3>
                    <p>
                        Att veta ditt TDEE är grunden för all viktkontroll. 
                        Om du äter exakt ditt TDEE kommer du att behålla din nuvarande vikt.
                    </p>
                    <ul>
                        <li>För att <strong>gå ner i vikt</strong> måste du ligga på ett kaloriunderskott (äta mindre än TDEE).</li>
                        <li>För att <strong>gå upp i vikt</strong> eller bygga muskler effektivt behöver du ett kaloriöverskott (äta mer än TDEE).</li>
                    </ul>

                    <h3>Så räknar vi ut ditt kaloribehov</h3>
                    <p>
                        Vår kalkylator använder <strong>Mifflin-St Jeor-ekvationen</strong>, som i studier har visat sig vara den mest 
                        tillförlitliga formeln för att uppskatta BMR för moderna livsstilar. Den tar hänsyn till din vikt, längd, 
                        ålder och kön.
                    </p>
                    <p>
                        Därefter multipliceras ditt BMR med en aktivitetsfaktor (PAL-värde) som sträcker sig från 1.2 (stillasittande) 
                        till 1.9 (extremt aktiv) för att få fram ditt totala dagsbehov.
                    </p>

                    <h3>Tips för att lyckas</h3>
                    <ol>
                        <li><strong>Var ärlig:</strong> Det är lätt att överskatta sin aktivitetsnivå. Välj den lägre nivån om du är osäker.</li>
                        <li><strong>Justera över tid:</strong> Kalkylatorn ger en uppskattning. Väg dig regelbundet och justera ditt intag baserat på dina resultat.</li>
                        <li><strong>Kvalitet räknas:</strong> Alla kalorier är inte likvärdiga. Försök att få i dig näringsrik mat även om du räknar kalorier.</li>
                    </ol>

                    <p>
                        Vill du veta om din vikt är hälsosam? Använd vår <a href="/">BMI-kalkylator</a> eller kolla din 
                        <a href="/idealvikt/">idealvikt</a> för fler riktmärken.
                    </p>
                </div>
            </div>

            <!-- Sidebar -->
            {% include 'components/sidebar.twig' %}

        </div>
    </div>
</div>

<script>
function tdeeCalculator() {
    return {
        age: '',
        gender: '',
        weight: '',
        height: '',
        activity: 1.55,
        
        activityLevels: [
            { value: 1.2, label: 'Stillasittande', desc: 'Kontorsarbete, ingen träning' },
            { value: 1.375, label: 'Lätt aktiv', desc: 'Lätt träning 1-3 dagar/vecka' },
            { value: 1.55, label: 'Måttligt aktiv', desc: 'Medelhård träning 3-5 dagar/vecka' },
            { value: 1.725, label: 'Mycket aktiv', desc: 'Hård träning 6-7 dagar/vecka' },
            { value: 1.9, label: 'Extremt aktiv', desc: 'Mycket hårt arbete eller träning 2 ggr/dag' }
        ],
        
        isValid() {
            return this.age && this.gender && this.weight && this.height && this.activity;
        },
        
        bmr() {
            const base = (10 * this.weight) + (6.25 * this.height) - (5 * this.age);
            return this.gender === 'male'
                ? Math.round(base + 5)
                : Math.round(base - 161);
        },
        
        tdee() {
            return Math.round(this.bmr() * this.activity);
        }
    }
}
</script>
{% endblock %}
