                            <a href="/bmi-formel/" class="text-gray-700 hover:text-brand-600 transition-colors">BMI Formel</a>
                        </li>
                    </ul>
                </div>

                <!-- CTA Widget -->
                <div class="bg-gradient-to-br from-brand-500 to-brand-600 rounded-xl shadow-lg p-6 text-white">
                    <h3 class="text-lg font-bold mb-2">Ozempic & Wegovy</h3>
                    <p class="text-sm text-brand-100 mb-4">Vill du veta om du uppfyller kraven för medicinsk viktbehandling?</p>
                    <a href="/bmi-ozempic-krav/" class="inline-flex items-center px-4 py-2 bg-white text-brand-600 rounded-lg font-semibold text-sm hover:bg-brand-50 transition-colors">
                        Kolla dina krav
